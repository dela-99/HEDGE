generator client {
  provider = "prisma-client-js"
  output   = "../../generated/prisma-client-payment"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Merchant {
  id                   String    @id @default(uuid())
  
  name                 String
  email                String    @unique
  isActive             Boolean   @default(true)
  
  businesses           Business[]
  linkedAccounts       LinkedAccount[]
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  @@index([email])
  @@index([isActive])
  @@index([createdAt])
}

model Business {
  id                   String    @id @default(uuid())
  
  merchantId           String
  merchant             Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  linkedAccounts       LinkedAccount[]
  members              BusinessMember[]
  
  name                 String
  businessType         String
  registrationNumber   String?
  
  isActive             Boolean   @default(true)
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  
  @@index([merchantId])
  @@index([isActive])
  @@index([createdAt])
}

enum BusinessRole {
  OWNER
  ADMIN
  FINANCE_MANAGER
  ANALYST
  VIEWER
}

model BusinessMember {
  id                   String       @id @default(uuid())

  businessId           String
  business             Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  userId               String
  role                 BusinessRole @default(VIEWER)

  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
  @@index([userId])
  @@index([role])
  @@index([createdAt])
}

enum PaymentProvider {
  MTN_MOMO
  AIRTEL
  VODAFONE
  ORANGE
  BANK_API
}

enum LinkedAccountStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

model LinkedAccount {
  id                   String              @id @default(uuid())

  merchantId           String
  merchant             Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  businessId           String
  business             Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)

  provider             PaymentProvider
  providerAccountId    String
  status               LinkedAccountStatus @default(PENDING)

  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@unique([provider, providerAccountId])
  @@index([merchantId])
  @@index([businessId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
}

model RawFinancialEvent {
  id                   String    @id @default(uuid())
  
  provider             String
  eventType            String
  providerReference    String
  
  headersJson          Json
  payloadJson          Json
  
  receivedAt           DateTime
  verificationStatus   String    @default("pending")
  
  createdAt            DateTime  @default(now())
  
  @@index([providerReference])
  @@index([provider])
  @@index([eventType])
  @@index([createdAt])
}
